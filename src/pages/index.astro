---
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const nav = [
  { label: "About", href: "#about" },
  { label: "Skills", href: "#skills" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];

const skills = [
  {
    group: "Core .NET Stack",
    icon: '<rect x="2" y="2" width="20" height="8" rx="2" /><rect x="2" y="14" width="20" height="8" rx="2" /><line x1="6" y1="6" x2="6.01" y2="6" /><line x1="6" y1="18" x2="6.01" y2="18" />',
    items: ["C#", "ASP.NET Core", "ASP.NET MVC", ".NET Framework", "Entity Framework / EF Core"],
  },
  {
    group: "Languages",
    icon: '<polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />',
    items: ["Java", "JavaScript", "Python", "Dart", "PHP", "C++", "SQL"],
  },
  {
    group: "Frameworks",
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2" /><polyline points="2 17 12 22 22 17" /><polyline points="2 12 12 17 22 12" />',
    items: ["Spring Boot", "Spring Security", "Express.js", "Node.js", "React", "Flutter", "JavaFX"],
  },
  {
    group: "Databases",
    icon: '<ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" />',
    items: ["SQL Server", "PostgreSQL", "MySQL", "MongoDB", "SQLite"],
  },
  {
    group: "Tools",
    icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />',
    items: ["Docker", "Apache Kafka", "Git & GitHub", "JPA / Hibernate", "Drift ORM", "WebSockets"],
  },
  {
    group: "Concepts",
    icon: '<rect x="4" y="4" width="16" height="16" rx="2" /><rect x="9" y="9" width="6" height="6" /><line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" /><line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" /><line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="14" x2="23" y2="14" /><line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="14" x2="4" y2="14" />',
    items: ["RESTful APIs", "Microservices", "OOP & SOLID", "Design Patterns", "DSA", "JWT Auth", "MVC"],
  },
];

const filters = [
  { label: "All", value: "all" },
  { label: ".NET", value: "dotnet" },
  { label: "Java / Spring", value: "java" },
  { label: "Node.js", value: "node" },
  { label: "AI / ML", value: "ml" },
  { label: "Mobile", value: "mobile" },
];

const projects = [
  {
    title: "Job Board REST API",
    description:
      "Fully documented REST API for job listings, applications, and employer/candidate profiles. JWT authentication with role-based authorization (Admin, Employer, Candidate) via ASP.NET Core Identity, repository pattern, and pagination for scalable data access.",
    tags: ["C#", "ASP.NET Core", "EF Core", "SQL Server", "JWT"],
    category: "dotnet",
    featured: true,
  },
  {
    title: "Instagram Clone",
    description:
      "Full-featured photo and video sharing platform with private messaging and user authentication. Built with ASP.NET MVC and Entity Framework on SQL Server, with a responsive Bootstrap frontend.",
    tags: ["C#", "ASP.NET MVC", "Entity Framework", "SQL Server", "Bootstrap"],
    category: "dotnet",
    repo: "https://github.com/OmarAyman415/Instagram",
    featured: true,
  },
  {
    title: "E-Commerce REST API",
    description:
      "Full REST API backend handling products, carts, and orders with Spring Data JPA and role-based access control via Spring Security — comparable in design to an ASP.NET Core Web API with EF Core.",
    tags: ["Java", "Spring Boot", "PostgreSQL", "JPA / Hibernate"],
    category: "java",
    repo: "https://github.com/OmarAyman415/shop",
    featured: true,
  },
  {
    title: "Microservices Architecture App",
    description:
      "Distributed system with async inter-service communication via Apache Kafka, fully containerized with Docker for consistent local and production environments.",
    tags: ["Node.js", "Express.js", "Apache Kafka", "Docker"],
    category: "node",
    repo: "https://github.com/OmarAyman415/MicroservicesKafkaDocker",
  },
  {
    title: "Real-Time Chat Application",
    description:
      "Secure real-time messaging using WebSockets with JWT and Spring Security authentication. The architecture mirrors ASP.NET Core + SignalR patterns and is easily portable to the .NET stack.",
    tags: ["Java", "Spring Boot", "WebSockets", "JWT", "Spring Security"],
    category: "java",
  },
  {
    title: "Lift Tracker",
    description:
      "Cross-platform workout tracking app with an offline-first SQLite database via Drift ORM — built with a clean MVVM architecture in Flutter.",
    tags: ["Flutter", "Dart", "SQLite", "Drift ORM"],
    category: "mobile",
  },
  {
    title: "Stereo R-CNN 3D Object Detection",
    description:
      "LiDAR-free 3D object detection system for autonomous driving using stereo cameras, validated on the KITTI benchmark with competitive accuracy.",
    tags: ["Python", "Deep Learning", "Computer Vision"],
    category: "ml",
    repo: "https://github.com/OmarAyman415/Stereo-RCNN",
  },
  {
    title: "Compiler Scanner",
    description:
      "Lexical scanner for a case-sensitive OOP language with a .NET-based UI — a deep dive into language processing concepts on the .NET platform.",
    tags: ["C#", "ASP.NET", ".NET"],
    category: "dotnet",
  },
  {
    title: "Fingerprint Recognition System",
    description:
      "ANN-based biometric identification system analyzing ridge endings and bifurcations for accurate fingerprint matching.",
    tags: ["Python", "Neural Networks"],
    category: "ml",
    repo: "https://github.com/OmarAyman415/Fingerprint-recognition",
  },
  {
    title: "Course Management System",
    description:
      "Desktop MVC application for managing courses, students, and assignments with a JavaFX interface.",
    tags: ["Java", "JavaFX", "MVC"],
    category: "java",
    repo: "https://github.com/OmarAyman415/CourseManagment",
  },
];

const timeline = [
  {
    period: "May 2025 — Present",
    title: "IT Operations Engineer",
    org: "e& Egypt (Etisalat Egypt) · Cairo, Egypt",
    body: "Maintaining IT infrastructure, monitoring system performance, and ensuring high availability of services at one of Egypt's largest telecom operators.",
  },
  {
    period: "2019 — 2023",
    title: "Computer Science",
    org: "Helwan University — Faculty of Computer & Artificial Intelligence",
    body: "Graduated with a 3.4 GPA. Built a foundation in OOP, SOLID principles, design patterns, and data structures & algorithms — then applied it across .NET, Spring, Node.js, and Flutter.",
  },
];

const facts = [
  { label: "Location", value: "Cairo, Egypt" },
  { label: "Degree", value: "Computer Science, Helwan University '23" },
  { label: "GPA", value: "3.4 / 4.0" },
  { label: "Languages", value: "Arabic (native) · English (intermediate)" },
  { label: "Status", value: "Open to backend & Spring Boot roles" },
];

const email = "omarayman40404@gmail.com";
const phone = "+20 100 939 8538";
const github = "https://github.com/OmarAyman415";
const linkedin = "https://linkedin.com/in/omar-ayman-723b401b4";
---

<Layout
  title="Omar Ayman — Backend & .NET Engineer"
  description="Portfolio of Omar Ayman Mohamed — backend engineer specializing in .NET, REST APIs, and microservices. Based in Cairo, Egypt."
>
  <div id="scroll-progress" aria-hidden="true"></div>

  <!-- Background: glow blobs + blueprint grid -->
  <div class="pointer-events-none fixed inset-0 overflow-hidden" aria-hidden="true">
    <div class="bg-grid absolute inset-x-0 top-0 h-[42rem]"></div>
    <div id="glow" class="absolute inset-0">
      <div class="glow-a absolute -top-60 left-1/2 h-180 w-250 -translate-x-1/2"></div>
      <div class="glow-b absolute top-1/3 -left-60 h-150 w-150"></div>
    </div>
  </div>

  <!-- Nav -->
  <header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-canvas/80 backdrop-blur-md">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5 sm:px-6 sm:py-4">
      <a href="#top" class="font-display text-lg font-bold text-fg">
        omar<span class="text-accent">.dev</span>
      </a>
      <ul class="hidden items-center gap-8 text-sm font-medium text-fg2 sm:flex">
        {
          nav.map((item) => (
            <li>
              <a href={item.href} data-navlink class="transition-colors hover:text-fg">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="flex items-center gap-2">
        <button
          id="theme-toggle"
          type="button"
          aria-label="Switch color theme"
          class="rounded-lg p-2 text-fg2 transition hover:bg-raised hover:text-fg"
        >
          <svg class="sun h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
          <svg class="moon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
        <a
          href="/OmarAymanResume.pdf"
          download
          class="rounded-lg border border-accent/40 px-4 py-1.5 text-sm font-medium text-accent transition hover:-translate-y-0.5 hover:bg-accent/10"
        >
          Résumé
        </a>
        <button
          id="menu-toggle"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="-mr-1 rounded-lg p-2 text-fg2 transition hover:bg-raised sm:hidden"
        >
          <svg id="icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-6 w-6" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg id="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden h-6 w-6" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      </div>
    </nav>
    <div
      id="mobile-menu"
      class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out sm:hidden"
    >
      <div class="overflow-hidden">
        <ul class="space-y-1 border-t border-line px-5 py-4">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="block rounded-lg px-3 py-2.5 text-base font-medium text-fg2 transition hover:bg-raised hover:text-accent"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </header>

  <main id="top" class="relative mx-auto max-w-5xl px-6">
    <!-- Hero -->
    <section class="flex min-h-svh flex-col justify-center pt-28 pb-16 sm:pt-24">
      <div class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
        <div>
          <p class="hero-enter mb-5 inline-flex items-center gap-2.5 rounded-full border border-line bg-surface px-3.5 py-1.5 text-xs font-medium text-fg2">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent2 opacity-60"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-accent2"></span>
            </span>
            Open to backend opportunities · Cairo, Egypt
          </p>
          <h1
            class="hero-enter font-display max-w-3xl text-[2.1rem] leading-[1.15] font-bold text-fg sm:text-5xl md:text-6xl"
          >
            Omar Ayman builds <span class="text-gradient">backend systems</span> that ship.
          </h1>
          <p class="hero-enter mt-5 max-w-2xl text-base leading-relaxed text-fg2 sm:mt-6 sm:text-lg">
            Backend &amp; .NET engineer with hands-on experience building REST APIs and
            microservices — from Entity Framework data layers to Kafka-driven distributed systems.
            Currently keeping the infrastructure running at one of Egypt's largest telecoms.
          </p>
          <div class="hero-enter mt-8 flex flex-col gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
            <a
              href="#projects"
              class="rounded-lg bg-accent px-6 py-3 text-center text-sm font-semibold text-on-accent transition hover:-translate-y-0.5 hover:shadow-lg hover:shadow-accent/25"
            >
              View my work
            </a>
            <a
              href="#contact"
              class="rounded-lg border border-line px-6 py-3 text-center text-sm font-semibold text-fg transition hover:-translate-y-0.5 hover:border-accent/50 hover:text-accent"
            >
              Get in touch
            </a>
            <div class="mt-2 flex items-center gap-5 text-fg3 sm:mt-0 sm:ml-2 sm:gap-4">
              <a href={github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="-m-2 p-2 transition-colors hover:text-accent">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
                  />
                </svg>
              </a>
              <a href={linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="-m-2 p-2 transition-colors hover:text-accent">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Terminal card -->
        <div class="hero-enter card hidden overflow-hidden rounded-2xl border border-line bg-surface shadow-2xl shadow-accent/5 lg:block" style="animation-delay: 0.55s;">
          <div class="flex items-center gap-2 border-b border-line px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
            <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
            <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
            <span class="ml-3 font-mono text-xs text-fg3">omar@cairo — zsh</span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-[13px] leading-relaxed text-fg2"><code><span class="text-fg3">$</span> <span class="text-accent">whoami</span> --verbose
&#123;
  <span class="text-accent">"name"</span>: <span class="text-accent2">"Omar Ayman"</span>,
  <span class="text-accent">"role"</span>: <span class="text-accent2">"Backend / .NET Engineer"</span>,
  <span class="text-accent">"focus"</span>: [<span class="text-accent2">"REST APIs"</span>, <span class="text-accent2">"Microservices"</span>],
  <span class="text-accent">"stack"</span>: [<span class="text-accent2">".NET"</span>, <span class="text-accent2">"Spring"</span>, <span class="text-accent2">"SQL"</span>, <span class="text-accent2">"Kafka"</span>],
  <span class="text-accent">"base"</span>: <span class="text-accent2">"Cairo, EG"</span>,
  <span class="text-accent">"status"</span>: <span class="text-accent2">"open_to_work"</span>
&#125;<span class="cursor">▍</span></code></pre>
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="reveal scroll-mt-24 py-14 sm:py-20">
      <h2 class="font-display mb-8 flex items-center gap-3 text-2xl font-bold text-fg sm:text-3xl">
        <span class="font-mono text-lg font-medium text-accent sm:text-xl">01.</span>
        About
        <span aria-hidden="true" class="ml-4 h-px max-w-60 flex-1 bg-line"></span>
      </h2>
      <div class="grid gap-10 md:grid-cols-5">
        <div class="space-y-4 leading-relaxed text-fg2 md:col-span-3">
          <p>
            I'm a Computer Science graduate from Helwan University with a focus on backend
            engineering and the .NET ecosystem. I enjoy designing clean, well-structured APIs and
            taking projects all the way from idea to production-ready.
          </p>
          <p>
            My foundation is built on OOP, SOLID principles, and design patterns — and I've applied
            it across stacks: ASP.NET Core, Spring Boot, Node.js, and Flutter. I'm comfortable with
            relational and NoSQL databases, containerization with Docker, and event-driven
            architectures with Kafka.
          </p>
          <p>
            Today I work as an IT Operations Engineer at e&amp; Egypt, where reliability isn't a
            buzzword — it's the job.
          </p>
        </div>
        <div class="md:col-span-2">
          <div class="card rounded-2xl border border-line bg-surface p-5 sm:p-6">
            <h3 class="font-display mb-4 text-sm font-semibold tracking-widest text-fg uppercase">
              Quick facts
            </h3>
            <dl class="space-y-3">
              {
                facts.map(({ label, value }) => (
                  <div>
                    <dt class="font-mono text-[11px] tracking-wider text-fg3 uppercase">{label}</dt>
                    <dd class="mt-0.5 text-sm text-fg2">{value}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class="reveal scroll-mt-24 py-14 sm:py-20">
      <h2 class="font-display mb-8 flex items-center gap-3 text-2xl font-bold text-fg sm:text-3xl">
        <span class="font-mono text-lg font-medium text-accent sm:text-xl">02.</span>
        Skills
        <span aria-hidden="true" class="ml-4 h-px max-w-60 flex-1 bg-line"></span>
      </h2>
      <div class="stagger grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          skills.map(({ group, icon, items }) => (
            <div class="card rounded-2xl border border-line bg-surface p-5 transition duration-300 hover:border-accent/30 sm:p-6">
              <div class="mb-4 flex items-center gap-3">
                <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent/10 text-accent">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-4.5 w-4.5"
                    aria-hidden="true"
                    set:html={icon}
                  />
                </span>
                <h3 class="font-display text-sm font-semibold tracking-widest text-fg uppercase">
                  {group}
                </h3>
              </div>
              <ul class="flex flex-wrap gap-2">
                {items.map((item) => (
                  <li class="rounded-full border border-line bg-raised px-3 py-1 text-xs font-medium text-fg2">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="reveal scroll-mt-24 py-14 sm:py-20">
      <h2 class="font-display mb-8 flex items-center gap-3 text-2xl font-bold text-fg sm:text-3xl">
        <span class="font-mono text-lg font-medium text-accent sm:text-xl">03.</span>
        Experience
        <span aria-hidden="true" class="ml-4 h-px max-w-60 flex-1 bg-line"></span>
      </h2>
      <div class="stagger relative space-y-12 border-l border-line pl-8">
        {
          timeline.map(({ period, title, org, body }) => (
            <div class="relative">
              <span class="absolute top-1 -left-[39px] h-3.5 w-3.5 rounded-full border-2 border-accent bg-canvas" />
              <p class="font-mono text-sm text-accent">{period}</p>
              <h3 class="font-display mt-2 text-xl font-semibold text-fg">{title}</h3>
              <p class="mt-1 text-fg2">{org}</p>
              <p class="mt-4 max-w-2xl leading-relaxed text-fg2">{body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="reveal scroll-mt-24 py-14 sm:py-20">
      <h2 class="font-display mb-3 flex items-center gap-3 text-2xl font-bold text-fg sm:text-3xl">
        <span class="font-mono text-lg font-medium text-accent sm:text-xl">04.</span>
        Projects
        <span aria-hidden="true" class="ml-4 h-px max-w-60 flex-1 bg-line"></span>
      </h2>
      <p class="mb-8 max-w-2xl text-fg2">
        A selection of things I've built — from production-style REST APIs to deep learning
        research. Cards with a GitHub icon link to source code.
      </p>
      <div class="mb-8 flex flex-wrap gap-2" role="group" aria-label="Filter projects by stack">
        {
          filters.map(({ label, value }) => (
            <button
              type="button"
              data-filter={value}
              aria-pressed={value === "all" ? "true" : "false"}
              class="rounded-full border border-line bg-surface px-4 py-1.5 text-sm font-medium text-fg2 transition hover:border-accent/40 hover:text-fg"
            >
              {label}
            </button>
          ))
        }
      </div>
      <div class="stagger grid gap-6 md:grid-cols-2 lg:grid-cols-3">
