---
interface Props {
  title: string;
  description: string;
  tags: string[];
  category: string;
  repo?: string;
  featured?: boolean;
}

const { title, description, tags, category, repo, featured = false } = Astro.props;
---

<article
  data-category={category}
  class="card group relative flex flex-col gap-4 rounded-2xl border border-line bg-surface p-5 transition duration-300 sm:p-6 hover:-translate-y-1 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/10"
>
  <div class="flex items-center gap-3">
    <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
      </svg>
    </span>
    {
      featured && (
        <span class="rounded-full border border-accent/30 bg-accent/10 px-2.5 py-0.5 text-[11px] font-medium text-accent">
          Featured
        </span>
      )
    }
    {
      repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} on GitHub`}
          class="-m-2 ml-auto shrink-0 p-2 text-fg3 transition-all duration-300 group-hover:-translate-y-0.5 hover:text-accent"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
            />
          </svg>
        </a>
      )
    }
  </div>
  <h3 class="font-display text-lg font-semibold text-fg transition-colors group-hover:text-accent">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-fg2">{description}</p>
  <ul class="mt-auto flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <li class="rounded-full border border-line bg-raised px-2.5 py-1 font-mono text-xs font-medium text-fg2">
          {tag}
        </li>
      ))
    }
  </ul>
</article>
